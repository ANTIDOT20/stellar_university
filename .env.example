# ─── USDC Asset ────────────────────────────────────────────────
NEXT_PUBLIC_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
NEXT_PUBLIC_USDC_CODE=USDC

# ─── Treasury & Admin ──────────────────────────────────────────
TREASURY_PUBLIC_KEY=
ADMIN_PUBLIC_KEY=
ADMIN_SECRET_KEY=

# ─── Auth / Session ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_32_byte_hex_secret_before_deploying
CHALLENGE_TTL_SECONDS=300

# ─── Database (Prisma) ─────────────────────────────────────────
DATABASE_URL=postgresql://stellaru:password@localhost:5432/stellaru_dev

# ─── IPFS / Pinata ─────────────────────────────────────────────
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_api_secret
PINATA_JWT=your_pinata_jwt_token
PINATA_GATEWAY=https://gateway.pinata.cloud

# ─── Anchor ────────────────────────────────────────────────────
ANCHOR_PLATFORM_URL=
SEP31_CALLBACK_URL=
# NEVER commit real secret keys — use a secrets manager in production
ANCHOR_OPERATOR_SECRET=
