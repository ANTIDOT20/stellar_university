ADMIN_PUBLIC_KEY=
ADMIN_SECRET_KEY=

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/stellaru

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your-secret-at-least-32-characters-long
CHALLENGE_TTL_SECONDS=60

# ── IPFS / Pinata ────────────────────────────────────────────
