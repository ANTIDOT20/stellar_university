{
  "name": "@stellaru/credential-sdk",
  "version": "0.1.0",
  "description": "StellarU credential verification SDK for the Stellar ecosystem",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test":  "vitest run"
  },
  "keywords": ["stellar", "soroban", "did", "credential", "university"],
  "license": "MIT",
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=12.0.0"
  },
  "devDependencies": {
    "tsup":      "^8.0.0",
    "typescript": "^5.3.0",
    "vitest":    "^1.3.0"
  }
}
